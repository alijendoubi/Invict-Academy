# Database (required)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# Auth (required)
JWT_SECRET=your-secret-key-min-32-chars

# Email via Resend (required for email features)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# File uploads via AWS S3 (required for document uploads)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=invict-documents

# Redis / BullMQ (optional — emails fall back to direct send if missing)
REDIS_URL=rediss://...

# App
NODE_ENV=production
