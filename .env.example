# ─────────────────────────────────────────────────────────────
# Invict Academy — Environment Configuration
# Copy this file to .env and fill in your real values

# ─── PostgreSQL Database ───────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/invict_academy?schema=public"

# ─── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ─── App Settings ─────────────────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@invictacademy.com"

# ─── WhatsApp (Twilio) ────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"   # Twilio sandbox number (or your approved number)

# ─── Redis (for BullMQ job queues) ────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── AWS S3 (Document Storage) ────────────────────────────────
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID="your_access_key_id"
AWS_SECRET_ACCESS_KEY="your_secret_access_key"
AWS_S3_BUCKET="invict-academy-docs"
